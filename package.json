{
    "name": "telegram-forwarder",
    "version": "1.0.0",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder --win"
    },
    "build": {
        "appId": "com.echatibot.app",
        "productName": "Echati Setup",
        "directories": {
            "output": "c:/Users/tverdy/Desktop/новый проект/версии/новая версия ечати/exe"
        },
        "win": {
            "target": "nsis"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "include": "installer.nsh"
        },
        "extraResources": [
            {
                "from": "backend_bin",
                "to": "backend_bin",
                "filter": [
                    "**/*"
                ]
            }
        ]
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.13.3"
    }
}